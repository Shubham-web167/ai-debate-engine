{
  "manifest_version": 3,
  "name": "SYNTRIX",
  "version": "1.0",
  "description": "SYNTRIX orchestrates autonomous debates between ChatGPT, Claude, and Gemini to synthesize perfect answers.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://*.chatgpt.com/*",
    "*://claude.ai/*",
    "*://*.claude.ai/*",
    "*://gemini.google.com/*",
    "*://*.gemini.google.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*"
      ],
      "js": [
        "utils/logger.js",
        "utils/selectorResolver.js",
        "adapters/baseAdapter.js",
        "adapters/chatgptAdapter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://claude.ai/*",
        "*://*.claude.ai/*"
      ],
      "js": [
        "utils/logger.js",
        "utils/selectorResolver.js",
        "adapters/baseAdapter.js",
        "adapters/claudeAdapter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://gemini.google.com/*",
        "*://*.gemini.google.com/*"
      ],
      "js": [
        "utils/logger.js",
        "utils/selectorResolver.js",
        "adapters/baseAdapter.js",
        "adapters/geminiAdapter.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["config/selectors.json"],
      "matches": [
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*",
        "*://claude.ai/*",
        "*://*.claude.ai/*",
        "*://gemini.google.com/*",
        "*://*.gemini.google.com/*"
      ]
    }
  ]
}
